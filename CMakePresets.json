{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "displayName": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/${presetName}"
        },
        {
            "name": "x86_64-debug",
            "inherits": "base",
            "displayName": "x86_64 kernel debug build",
            "toolchainFile": "${sourceDir}/tools/cmake/gcc-x86_64-elf-nasm-toolchain.cmake",
            "cacheVariables": { "CMAKE_BUILD_TYPE" : "Debug" }
        }
    ],
    "buildPresets": [
        { "name": "x86_64-debug", "configurePreset": "x86_64-debug" }
    ]
}
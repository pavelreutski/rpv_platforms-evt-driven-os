{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "displayName": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS" : "ON"
            }
        },
        {
            "inherits": "base",
            "name": "x86_64-debug",
            "displayName": "x86_64 kernel debug build",
            "toolchainFile": "${sourceDir}/tools/cmake/gcc-x86_64-elf-nasm-toolchain.cmake",
            "cacheVariables": { 
                "KERNEL_TARGET" : "x86_64",
                "CMAKE_BUILD_TYPE" : "Debug" }
        },
        {
            "inherits": "base",
            "name": "microchip_avr-debug",            
            "displayName": "Microchip AVR kernel debug build",
            "toolchainFile": "${sourceDir}/tools/cmake/gcc-avr-toolchain.cmake",
            "cacheVariables": {
                "KERNEL_TARGET" : "microchip_avr",
                "CMAKE_BUILD_TYPE" : "Debug" }
        }
    ],
    "buildPresets": [
        { "name": "x86_64-debug", "configurePreset": "x86_64-debug" },
        { "name": "microchip_avr-debug", "configurePreset": "microchip_avr-debug" }
    ]
}